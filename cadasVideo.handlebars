<h1>Cadastrar Vídeo</h1>
<form action="/videos" method="POST">
    <div>
        <label>Título:</label><br>
        <input type="text" name="titulo" required>
    </div>
    <div>
        <label>Criador:</label><br>
        <input type="text" name="criador" required>
    </div>
    <div>
        <label>Descrição:</label><br>
        <textarea name="descricao" required></textarea>
    </div>
    <div>
        <label>Visualizações:</label><br>
        <input type="number" name="visualizacoes" required>
    </div>
    <div>
        <label>Curtidas:</label><br>
        <input type="number" name="curtidas" required>
    </div>
    <div>
        <label>Hashtag:</label><br>
        <input type="text" name="hashtag" required>
    </div>
    <div>
        <label>URL do Vídeo:</label><br>
        <input type="url" name="url" required>
    </div>
    <div>
        <label>URL da Thumbnail:</label><br>
        <input type="url" name="thumbnail" required>
    </div>
    <br>
    <button type="submit">Cadastrar</button>
</form>
<a href="/videos">Voltar para Lista</a>
